# LetsMakeIt Environment Settings
# Rename this to .env for deployment

# Database
# For Docker: postgresql://lmi_user:change_me_in_env@db/lmi_db
# For Local: postgresql://lmi_user:change_me_in_env@localhost/lmi_db
SQLALCHEMY_DATABASE_URL=postgresql://lmi_user:change_me_in_env@db/lmi_db
SECRET_KEY=change_me_to_something_very_long_and_random

# API Settings
DEBUG=False
PROJECT_NAME="LetsMakeIt"
PROJECT_DESCRIPTION="A modular full-stack portal."
ALLOWED_ORIGINS="http://localhost,http://localhost:8080,https://portal.lets-make-it.hu"
